    "뷰티": [
      {
        "cluster_id": "352a9d01-0275-4b14-8537-9438cd4807a2",
        "title_ko": "올리브영, 광장시장 K뷰티 거점화",
        "summary_ko": "올리브영이 서울 광장시장 내 244평 규모의 '광장마켓점'을 열었다. 1960년대 복고풍 인테리어에 K뷰티를 결합한 '올영양행' 콘셉트로, 방한 외국인의 전통시장 방문을 K뷰티 구매로 연결하는 관광 연계 전략이 핵심이다.",
        "is_paywalled": false
      },
      {
        "cluster_id": "20d6d408-7c2a-4368-9cb3-f0073d089301",
        "title_ko": "K뷰티 수출, 유통사가 판가름",
        "summary_ko": "2025년 화장품 수출액이 114억 달러로 역대 최대를 경신했고, 올 1분기도 분기 기준 최고치를 이어갔다. 제품 경쟁력 못지않게 현지 유통 네트워크를 보유한 글로벌 유통사의 역할이 성장 지속 여부를 가르는 변수로 떠올랐다.",
        "is_paywalled": false
      },
      {
        "cluster_id": "1c29c278-f4c3-470f-9134-25f2ebbed434",
        "title_ko": "더후 천기단, 유전자 과학으로 전환",
        "summary_ko": "LG생활건강 더후가 2023년 리뉴얼 후 불과 3년 만에 천기단 3세대를 공개했다. 성분 헤리티지 중심 스토리텔링에서 '데이터 기반 안티에이징'으로 전략 축을 바꾸며, 럭셔리 한방 화장품의 세대교체 주기 자체가 빨라지고 있다.",
        "is_paywalled": false
      }
    ],
    "패션": [
      {
        "cluster_id": "e7a7730a-5802-4254-92f1-00dd0177e772",
        "title_ko": "남성 레트로 스니커즈 롱런",
        "summary_ko": "해외 패션 매체들이 시즌을 막론하고 남성 레트로 스니커즈를 '불변의 아이템'으로 재조명하고 있다. 트렌드 주기가 짧아진 신발 시장에서 클래식 실루엣의 내구성 있는 수요가 확인된다.",
        "is_paywalled": false
      },
      {
        "cluster_id": "09437bd4-2d86-4a92-9854-0e4583ba37aa",
        "title_ko": "스트릿 댄스, 패션 소비 접점 확대",
        "summary_ko": "'월드 오브 스트릿 우먼 파이터' 등 댄스 콘텐츠가 스트릿 패션 소비의 직접 촉매로 작동하고 있다. 공연·미디어와 의류 구매가 하나의 문화 경험으로 묶이는 흐름이 뚜렷해지고 있다.",
        "is_paywalled": false
      },
      {
        "cluster_id": "a2bd4966-9cf6-4e2e-94a1-8a3a8d8bcc97",
        "title_ko": "K-문화 팝업, 패션·식음료 결합",
        "summary_ko": "서초·강남역 일대 케미스트릿 팝업이 K-패션, K-푸드, K-뷰티를 한 공간에 묶어 선보였다. 단일 카테고리 팝업에서 복합 K-문화 체험형 공간으로의 전환이 가속되고 있다.",
        "is_paywalled": false
      }
    ],
    "라이프스타일": [
      {
        "cluster_id": "f213ee31-56c9-46fb-93b6-354b5dea1ed2",
        "title_ko": "삼다수 프로모션, 5성급 한 달 살기 제공",
        "summary_ko": "제주삼다수가 여행지원금에 더해 5성급 호텔 한 달 살기 기회를 경품으로 내걸었다. 생수 브랜드가 체류형 관광 소비와 직접 연결되는 이례적인 프로모션으로, 일상 소비재의 경험 가치 확장 전략이 두드러진다.",
        "is_paywalled": false
      },
      {
        "cluster_id": "eaca8da2-899c-4ea9-85d4-02ea9e3f3ef9",
        "title_ko": "호텔 객실코디, 정년 없는 전문직으로",
        "summary_ko": "부산 수영구가 호텔 객실코디 전문인력 양성사업 수료식을 열었다. 비대면·고령층 친화 직무로 설계된 이 사업은 호텔 서비스 인력 구조 다변화와 중장년 재취업 수요가 맞물린 흐름을 보여준다.",
        "is_paywalled": false
      }
    ],
    "소비트렌드": [
      {
        "cluster_id": "1c95dc4e-91a7-401d-9149-f41a1c5d9c49",
        "title_ko": "중국 Z세대, 한복으로 문화소비 표출",
        "summary_ko": "중국 Z세대 사이에서 한복(汉服) 착용이 문화적 자부심과 연결된 소비 행태로 자리잡고 있다. '국조(国潮)' 흐름과 맞물려 전통 의복이 패션 소비의 정체성 표현 수단으로 기능하고 있다.",
        "is_paywalled": false
      },
      {
        "cluster_id": "b6e6f34b-7c9a-4bf6-8d6c-f9af1afaa41c",
        "title_ko": "구독형 보험 시대 임박",
        "summary_ko": "국내 보험업계에서 구독형 보험 모델 도입 논의가 본격화되고 있다. 구독 경제의 소비 습관이 금융 서비스 영역으로 침투하며, 단기 해지·재가입이 자유로운 유연한 보장 상품 수요가 커지고 있다.",
        "is_paywalled": false
      }
    ]
  },
  "insight_box_ko": "오늘 클러스터를 관통하는 흐름은 '소비의 경험 밀도 상승'이다. 올리브영의 광장시장 입점, 삼다수의 체류형 관광 프로모션, K-문화 복합 팝업 모두 단순 구매를 문화 경험과 결합하는 전략이다. 뷰티 섹션에서는 더후의 세대교체 가속과 K뷰티 유통 네트워크 고도화가 동시에 진행되며, 제품 혁신과 유통 혁신이 함께 달리는 구도가 선명해졌다. 구독형 보험과 Z세대 관심사 소비까지 더하면, 소비자들이 '소유'보다 '경험·정체성·지속 관계'에 지갑을 여는 전환이 카테고리 경계를 넘어 동시 진행 중임을 확인할 수 있다.",
